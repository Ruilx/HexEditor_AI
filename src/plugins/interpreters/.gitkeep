//   UnicodeInterpreter.js  — UTF-8 / UTF-16 / UTF-32 码点
//   GbkInterpreter.js      — GBK / GB18030 / SHIFT-JIS / Big5
//   HashInterpreter.js     — MD5 / SHA1 / CRC32（延迟计算）
